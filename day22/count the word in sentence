#include <stdio.h>

int main() {
    char str[200];
    int i = 0, words = 0;

    printf("Enter a sentence: ");
    fgets(str, sizeof(str), stdin);

    // Traverse the string
    while (str[i] != '\0') {
        // A word is detected when we find a non-space character
        // followed by either a space or end of string
        if (str[i] != ' ' && str[i] != '\n') {
            if (str[i + 1] == ' ' || str[i + 1] == '\n' || str[i + 1] == '\0') {
                words++;
            }
        }
        i++;
    }

    printf("Number of words: %d\n", words);

    return 0;
}
