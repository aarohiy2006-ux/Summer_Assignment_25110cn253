#include <stdio.h>

int main() {
    int n;
    long long a = 0, b = 1, next;

    printf("Enter n: ");
    scanf("%d", &n);

    if (n == 1) {
        printf("The 1st Fibonacci term is %lld\n", a);
    } else if (n == 2) {
        printf("The 2nd Fibonacci term is %lld\n", b);
    } else {
        for (int i = 3; i <= n; i++) {
            next = a + b;
            a = b;
            b = next;
        }
        printf("The %dth Fibonacci term is %lld\n", n, b);
    }

    return 0;
}
