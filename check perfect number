#include <stdio.h>

int main() {
    int n, sum = 0;

    // Input from user
    printf("Enter a number: ");
    scanf("%d", &n);

    // Check sum of divisors
    for (int i = 1; i < n; i++) {
        if (n % i == 0) {
            sum += i;
        }
    }

    // Determine if perfect
    if (sum == n) {
        printf("%d is a Perfect Number\n", n);
    } else {
        printf("%d is not a Perfect Number\n", n);
    }

    return 0;
}
