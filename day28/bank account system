#include <stdio.h>
#include <string.h>

#define MAX 100

struct Account {
    int accNo;
    char name[50];
    float balance;
};

struct Account bank[MAX];
int count = 0;

// Create a new account
void createAccount() {
    if (count >= MAX) {
        printf("Bank database is full!\n");
        return;
    }

    printf("\nEnter Account Number: ");
    scanf("%d", &bank[count].accNo);

    getchar(); // Clear input buffer

    printf("Enter Account Holder Name: ");
    fgets(bank[count].name, sizeof(bank[count].name), stdin);
    bank[count].name[strcspn(bank[count].name, "\n")] = 0;

    printf("Enter Initial Deposit: ");
    scanf("%f", &bank[count].balance);

    printf("Account created successfully!\n");
    count++;
}

// Deposit money
void deposit() {
    int accNo;
    float amount;
    int found = 0;

    printf("\nEnter Account Number: ");
    scanf("%d", &accNo);

    for (int i = 0; i < count; i++) {
        if (bank[i].accNo == accNo) {
            printf("Enter Deposit Amount: ");
            scanf("%f", &amount);

            bank[i].balance += amount;
            printf("Deposit Successful!\n");
            printf("Current Balance: %.2f\n", bank[i].balance);
            found = 1;
            break;
        }
    }

    if (!found)
        printf("Account not found!\n");
}

// Withdraw money
void withdraw() {
    int accNo;
    float amount;
    int found = 0;

    printf("\nEnter Account Number: ");
    scanf("%d", &accNo);

    for (int i = 0; i < count; i++) {
        if (bank[i].accNo == accNo) {
            printf("Enter Withdrawal Amount: ");
            scanf("%f", &amount);

            if (amount > bank[i].balance)
                printf("Insufficient Balance!\n");
            else {
                bank[i].balance -= amount;
                printf("Withdrawal Successful!\n");
                printf("Remaining Balance: %.2f\n", bank[i].balance);
            }

            found = 1;
            break;
        }
    }

    if (!found)
        printf("Account not found!\n");
}

// Check balance
void checkBalance() {
    int accNo;
    int found = 0;

    printf("\nEnter Account Number: ");
    scanf("%d", &accNo);

    for (int i = 0; i < count; i++) {
        if (bank[i].accNo == accNo) {
            printf("\nAccount Holder: %s\n", bank[i].name);
            printf("Current Balance: %.2f\n", bank[i].balance);
            found = 1;
            break;
        }
    }

    if (!found)
        printf("Account not found!\n");
}

// Display all accounts
void displayAccounts() {
    if (count == 0) {
        printf("\nNo accounts available.\n");
        return;
    }

    printf("\n--------------------------------------------------\n");
    printf("Acc No\tName\t\tBalance\n");
    printf("--------------------------------------------------\n");

    for (int i = 0; i < count; i++) {
        printf("%d\t%s\t\t%.2f\n",
               bank[i].accNo,
               bank[i].name,
               bank[i].balance);
    }
}

int main() {
    int choice;

    while (1) {
        printf("\n===== BANK ACCOUNT MANAGEMENT SYSTEM =====\n");
        printf("1. Create Account\n");
        printf("2. Deposit Money\n");
        printf("3. Withdraw Money\n");
        printf("4. Check Balance\n");
        printf("5. Display All Accounts\n");
        printf("6. Exit\n");

        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                createAccount();
                break;
            case 2:
                deposit();
                break;
            case 3:
                withdraw();
                break;
            case 4:
                checkBalance();
                break;
            case 5:
                displayAccounts();
                break;
            case 6:
                printf("Thank you for using the Bank Account Management System.\n");
                return 0;
            default:
                printf("Invalid choice! Please try again.\n");
        }
    }

    return 0;
}bank account 
